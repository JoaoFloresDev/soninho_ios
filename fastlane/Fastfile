# Fastfile for Soninho
default_platform(:ios)

platform :ios do
# sync_screenshots_initial — generated by scripts/scaffold-screenshots-tool.sh.
# Required env vars when invoked:
#   APP_STORE_CONNECT_KEY_ID
#   APP_STORE_CONNECT_ISSUER_ID
#   APP_STORE_CONNECT_KEY_PATH

  desc "Push initial screenshots (single set per locale, 6.9\") to the"
  desc "App Store DEFAULT product page. Run this for first submission of a"
  desc "new app, after `swift run SoninhoScreenshots initial` has"
  desc "rendered the PNGs into ./screenshots/initial/<locale>/."
  desc ""
  desc "For A/B test (PPO experiments) post-launch use upload_ppo.py instead —"
  desc "fastlane deliver does NOT support PPO experiment uploads."
  lane :sync_screenshots_initial do
    screenshots_dir = "./screenshots/initial"

    UI.user_error!("Folder #{screenshots_dir} not found — run `swift run SoninhoScreenshots initial` first") unless File.directory?(screenshots_dir)

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_PATH"],
      duration: 1200,
      in_house: false
    )

    deliver(
      api_key: api_key,
      app_identifier: "com.gambitstudio.soninho",
      platform: "ios",
      screenshots_path: screenshots_dir,
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: true,
      overwrite_screenshots: true,
      force: true,
      submit_for_review: false,
      run_precheck_before_submit: false,
      languages: ["pt-BR", "es-ES"]
    )
  end
end
