    },
    "NSHealthShareUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slumber uses your sleep data to provide detailed sleep analysis and personalized insights to help you sleep better."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sueñito utiliza tus datos de sueño para proporcionar un análisis detallado y consejos personalizados que te ayuden a dormir mejor."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soninho usa seus dados de sono para fornecer análises detalhadas e insights personalizados para ajudá-lo a dormir melhor."
          }
        }
      }
    },
    "NSMotionUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slumber uses motion sensors to detect your sleep phases and wake you at the optimal moment during light sleep."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sueñito usa los sensores de movimiento para detectar tus fases de sueño y despertarte en el momento óptimo durante el sueño ligero."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soninho usa os sensores de movimento para detectar suas fases de sono e acordá-lo no momento ideal durante o sono leve."
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slumber uses the microphone to measure ambient sound levels during sleep to improve sleep phase detection accuracy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sueñito usa el micrófono para medir los niveles de sonido ambiental durante el sueño y mejorar la precisión de la detección de fases de sueño."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soninho usa o microfone para medir os níveis de som ambiente durante o sono e melhorar a precisão da detecção de fases de sono."
          }
        }
      }
    },
    "NSHealthUpdateUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slumber saves your sleep records to Apple Health so you can track your sleep history across all your devices."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sueñito guarda tus registros de sueño en Apple Salud para que puedas acompañar tu historial de sueño en todos tus dispositivos."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soninho salva seus registros de sono no Apple Saúde para que você possa acompanhar seu histórico de sono em todos os seus dispositivos."
          }
        }
      }
    }
  },
  "version" : "1.0"
