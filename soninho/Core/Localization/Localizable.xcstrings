    "tip_exercise_desc": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Regular exercise improves sleep quality, but avoid intense workouts close to bedtime."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El ejercicio regular mejora la calidad del sueño, pero evita entrenamientos intensos cerca de la hora de dormir."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Exercícios regulares melhoram a qualidade do sono, mas evite treinos intensos perto da hora de dormir."
          }
        }
      }
    },
    "tip_exercise_title": {
      "extractionState": "stale",
