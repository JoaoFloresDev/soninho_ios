    "tip_dark_room_desc": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use blackout curtains or an eye mask to block light and boost melatonin production."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa cortinas opacas o una máscara para bloquear la luz y aumentar la producción de melatonina."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use cortinas blackout ou máscara de dormir para bloquear a luz e aumentar a produção de melatonina."
          }
        }
      }
    },
    "tip_dark_room_title": {
