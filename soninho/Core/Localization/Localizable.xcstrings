    "tip_heavy_meals_desc": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don't eat large meals within 2-3 hours of bedtime to avoid digestive discomfort."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No comas comidas grandes 2-3 horas antes de dormir para evitar molestias digestivas."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não coma refeições grandes 2-3 horas antes de dormir para evitar desconforto digestivo."
          }
        }
      }
    },
