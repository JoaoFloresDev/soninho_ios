    "tip_breathing_desc": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Try the 4-7-8 technique: inhale for 4s, hold for 7s, exhale for 8s to calm your mind."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prueba la técnica 4-7-8: inhala 4s, mantén 7s, exhala 8s para calmar tu mente."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Experimente a técnica 4-7-8: inspire 4s, segure 7s, expire 8s para acalmar sua mente."
          }
        }
      }
    },
    "tip_breathing_title": {
      "extractionState": "stale",
      "localizations": {
