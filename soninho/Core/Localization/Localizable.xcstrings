    "onboarding_subtitle_1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Understand your sleep patterns with detailed analysis of deep, light, and REM sleep stages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprende tus patrones de sueño con análisis detallado de las fases de sueño profundo, ligero y REM."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Entenda seus padrões de sono com análise detalhada das fases de sono profundo, leve e REM."
          }
        }
      }
    },
    "onboarding_subtitle_2": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See your sleep quality trends, average bedtime, and how your sleep improves over time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve las tendencias de calidad del sueño, hora promedio de dormir y cómo mejora tu sueño con el tiempo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja tendências de qualidade do sono, horário médio de dormir e como seu sono melhora com o tempo."
          }
        }
      }
    },
    "onboarding_subtitle_3": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wake up at the optimal moment during light sleep for a refreshed and energized morning."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Despierta en el momento óptimo durante el sueño ligero para una mañana fresca y llena de energía."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acorde no momento ideal durante o sono leve para uma manhã revigorada e energizada."
          }
        }
      }
    },
    "onboarding_subtitle_4": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sync with Apple Health to get a complete picture of your wellness and sleep data."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sincroniza con Apple Salud para obtener una imagen completa de tu bienestar y datos de sueño."
