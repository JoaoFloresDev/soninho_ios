    "tip_consistent_schedule_desc": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Go to bed and wake up at the same time every day, even on weekends."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acuéstate y despierta a la misma hora todos los días, incluso los fines de semana."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Durma e acorde no mesmo horário todos os dias, mesmo nos fins de semana."
          }
        }
      }
    },
