    "tip_meditation_desc": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Even 5-10 minutes of meditation before bed can reduce stress and improve sleep quality."
          }
        },
