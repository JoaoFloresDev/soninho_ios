      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drink enough water during the day, but reduce intake before bed to minimize nighttime awakenings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Bebe suficiente agua durante el día, pero reduce la ingesta antes de dormir."
