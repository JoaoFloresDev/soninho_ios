    "tip_cool_room_desc": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The ideal sleep temperature is between 60-67°F (15-19°C)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La temperatura ideal para dormir está entre 15-19°C."
          }
        },
