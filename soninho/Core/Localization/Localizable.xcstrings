          }
        }
      }
    },
    "tip_daylight_desc": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Spend at least 30 minutes outside during the day to support your natural sleep-wake cycle."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasa al menos 30 minutos afuera durante el día para apoyar tu ciclo natural de sueño."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Passe pelo menos 30 minutos ao ar livre durante o dia para apoiar seu ciclo natural de sono."
          }
        }
      }
    },
