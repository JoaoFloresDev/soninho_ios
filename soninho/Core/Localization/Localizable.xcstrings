    "onboarding_subtitle_1" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Understand your sleep patterns with detailed analysis of deep, light, and REM sleep stages." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Entenda seus padrões de sono com análise detalhada das fases de sono profundo, leve e REM." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Comprende tus patrones de sueño con análisis detallado de las fases de sueño profundo, ligero y REM." } }
