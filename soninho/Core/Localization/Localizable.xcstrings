    "tracker_battery_info_message" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sleep tracking and smart alarm run in background and may use additional battery. For best results, keep your device charged overnight."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El monitoreo del sueño y la alarma inteligente funcionan en segundo plano y pueden usar batería adicional. Para mejores resultados, mantén tu dispositivo cargando durante la noche."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O monitoramento de sono e alarme inteligente funcionam em segundo plano e podem usar bateria adicional. Para melhores resultados, mantenha o dispositivo carregando durante a noite."
          }
        }
      }
